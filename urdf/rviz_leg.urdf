<?xml version="1.0"?>

<robot name="rviz_leg">

<link name="base_link">
  <visual>
    <geometry>
      <box size="0.05 0.05 0.05"/>
    </geometry>
  </visual>
</link>


<link name="upper_leg">
  <visual>
    <origin xyz="0 0 -0.1"/>
    <geometry>
      <cylinder radius="0.015" length="0.2"/>
    </geometry>
  </visual>
</link>


<link name="lower_leg">
  <visual>
    <origin xyz="0 0 -0.1"/>
    <geometry>
      <cylinder radius="0.012" length="0.2"/>
    </geometry>
  </visual>
</link>


<link name="foot">
  <visual>
    <geometry>
      <box size="0.08 0.03 0.02"/>
    </geometry>
  </visual>
</link>



<joint name="Hip" type="revolute">

<parent link="base_link"/>

<child link="upper_leg"/>

<origin xyz="0 0 0"/>

<axis xyz="0 1 0"/>

<limit lower="-1.57" upper="1.57" effort="10" velocity="10"/>

</joint>




<joint name="Knee" type="revolute">

<parent link="upper_leg"/>

<child link="lower_leg"/>

<origin xyz="0 0 -0.2"/>

<axis xyz="0 1 0"/>

<limit lower="-1.57" upper="1.57" effort="10" velocity="10"/>

</joint>




<joint name="Ankle" type="revolute">

<parent link="lower_leg"/>

<child link="foot"/>

<origin xyz="0 0 -0.2"/>

<axis xyz="0 1 0"/>

<limit lower="-1.57" upper="1.57" effort="10" velocity="10"/>

</joint>


</robot>
